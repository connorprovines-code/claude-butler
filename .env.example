# Claude Butler Configuration
# Copy this to .env and fill in your values: cp .env.example .env

# ──── Core (Required) ────
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (message @userinfobot to get it)
# Comma-separated for multiple authorized users
ALLOWED_USER_IDS=
# Path to Claude CLI binary (leave as 'claude' if it's in PATH)
CLAUDE_CLI_PATH=claude

# ──── Agent Settings ────
MAX_CONCURRENT_AGENTS=2
AGENT_TIMEOUT_SECONDS=300
RATE_LIMIT_PER_MINUTE=10
SESSION_TTL_MINUTES=30

# ──── GitHub (Optional) ────
# Classic Personal Access Token (no expiry recommended)
# https://github.com/settings/tokens → Generate new token (classic)
# Scopes: repo, read:org
GH_TOKEN=

# ──── Gmail (Optional) ────
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# ──── Notion (Optional) ────
# https://www.notion.so/profile/integrations
# Also configure .mcp.json for MCP tool access (see .mcp.json.example)
NOTION_API_KEY=

# ──── Google Calendar (Optional) ────
# Requires gcalcli + OAuth setup. See README.
# Install: python3 -m venv .venv && .venv/bin/pip install gcalcli
# Auth: .venv/bin/gcalcli --client-id=YOUR_ID --client-secret=YOUR_SECRET list
GCALCLI_PATH=.venv/bin/gcalcli
GCALCLI_CLIENT_ID=
GCALCLI_CLIENT_SECRET=

# ──── Advanced ────
# Default working directory for agents (defaults to project root)
# DEFAULT_CWD=
