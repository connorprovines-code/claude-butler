# Claude Butler Configuration
# Copy this to .env and fill in your values

# ──── Telegram ────
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (send /start to @userinfobot to get it)
# Comma-separated for multiple authorized users
ALLOWED_USER_IDS=

# ──── Rate Limiting ────
# Max concurrent Claude agents (default: 2)
MAX_CONCURRENT_AGENTS=2

# Max messages per minute per user (default: 10)
RATE_LIMIT_PER_MINUTE=10

# Max agent runtime in seconds before kill (default: 300 = 5 min)
AGENT_TIMEOUT_SECONDS=300

# ──── Email (Optional) ────
# For email-checking skills
# GMAIL_ADDRESS=
# GMAIL_APP_PASSWORD=

# ──── Paths ────
# Where Claude CLI is installed (leave blank for PATH default)
# CLAUDE_CLI_PATH=claude

# Default working directory for agents
# DEFAULT_CWD=
